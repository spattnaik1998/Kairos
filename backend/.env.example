# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# HuggingFace token (optional — TimesFM 2.5 is public, but token speeds up downloads)
HF_TOKEN=

# Backend settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Cache
CACHE_DB_PATH=./data/kairos_cache.duckdb
CACHE_TTL_SECONDS=3600
